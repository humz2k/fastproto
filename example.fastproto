

namespace my_namespace {

message SimpleMessage(1){
    simple_int_field : int32;
}

namespace my_sub_namespace::my_next_sub_namespace {

message MessageWithString(2){
    my_int_field : int32;
    my_string_field : string;
}

}

message MessageWithArray(3) {
    my_array_field : array<SimpleMessage>;
}

}